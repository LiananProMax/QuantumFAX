# =============================================================================
# PaddleOCR-VL Server 环境变量配置
#
# 将此文件复制为 .env 并根据需要修改配置
# =============================================================================

# ---- 应用配置 ----
APP_NAME=PaddleOCR-VL Server
APP_VERSION=1.0.0

# ---- 服务器配置 ----
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__WORKERS=1
SERVER__DEBUG=false
# CORS 允许的来源，多个用逗号分隔
SERVER__CORS_ORIGINS=["*"]

# ---- 模型配置 ----
# 推理设备: gpu:0, gpu:1, cpu
MODEL__DEVICE=gpu:0
# PaddleOCR-VL 版本: v1, v1.5
MODEL__PIPELINE_VERSION=v1.5
# 推理精度: fp32, fp16
MODEL__PRECISION=fp16
# 是否启动时预热模型
MODEL__MODEL_WARMUP=true
# 功能开关
MODEL__USE_DOC_ORIENTATION_CLASSIFY=false
MODEL__USE_DOC_UNWARPING=false
MODEL__USE_LAYOUT_DETECTION=true
MODEL__USE_SEAL_RECOGNITION=false
MODEL__USE_CHART_RECOGNITION=false
# 高性能推理
MODEL__ENABLE_HPI=false
MODEL__USE_TENSORRT=false

# ---- 认证配置 ----
# 是否启用 API Key 认证
AUTH__ENABLED=true
# API Key 列表，JSON 数组格式。留空 [] 则自动生成
# 示例: AUTH__API_KEYS=["key1","key2"]
AUTH__API_KEYS=[]
# API Key Header 名称
AUTH__API_KEY_HEADER=X-API-Key

# ---- 限流配置 ----
# 是否启用限流
RATE_LIMIT__ENABLED=true
# 每分钟最大请求数
RATE_LIMIT__REQUESTS_PER_MINUTE=60
# 每天最大请求数
RATE_LIMIT__REQUESTS_PER_DAY=10000
# 突发请求数上限
RATE_LIMIT__BURST_SIZE=10

# ---- 日志配置 ----
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG__LEVEL=INFO
# 日志文件路径
LOG__FILE=logs/ocr_server.log
# 日志轮转大小
LOG__ROTATION=10 MB
# 日志保留时间
LOG__RETENTION=30 days

# ---- 存储配置 ----
# 临时文件目录
STORAGE__TEMP_DIR=temp
# 输出文件目录
STORAGE__OUTPUT_DIR=output
# 最大上传文件大小 (字节), 默认 20MB
STORAGE__MAX_UPLOAD_SIZE=20971520
